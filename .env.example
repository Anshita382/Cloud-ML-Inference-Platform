# Copy this to .env and customize
# cp .env.example .env

# Application
APP_NAME=cloud-ml-inference-platform
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_STREAM_KEY=inference:stream
REDIS_CONSUMER_GROUP=inference-workers

# Model
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
MODEL_CACHE_DIR=/app/model/cache
MODEL_DEVICE=cpu

# Batching — tune these for your hardware
BATCH_MAX_SIZE=16
BATCH_TIMEOUT_MS=50
BATCH_ENABLED=true

# Worker
WORKER_COUNT=2
WORKER_POLL_INTERVAL_MS=10

# Monitoring
PROMETHEUS_PORT=8001
METRICS_ENABLED=true

# AWS (Phase 5)
# AWS_REGION=us-east-1
# MODEL_S3_PATH=s3://your-bucket/models/
